{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/gite-in-barca", "destination": "/taxi-boat-lake-como", "permanent": true },
    { "source": "/esperienze", "destination": "/experiences", "permanent": true },
    { "source": "/prenotazione", "destination": "/booking", "permanent": true },
    { "source": "/chi-siamo", "destination": "/about", "permanent": true },
    { "source": "/contatti", "destination": "/contact", "permanent": true }
  ]
}
